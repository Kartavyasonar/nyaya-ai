# ═══════════════════════════════════════════
# NYAYA AI — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════

# App
APP_NAME=NyayaAI
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your_super_secret_key_change_this_in_production
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/nyaya_ai?retryWrites=true&w=majority

# Redis (for caching + sessions)
REDIS_URL=redis://localhost:6379

# Groq LLM API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Hugging Face
HF_TOKEN=your_huggingface_token_here
EMBEDDING_MODEL=l3cube-pune/hindi-sentence-similarity-sbert
TRANSLATION_MODEL=ai4bharat/indictrans2-indic-en-1B

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Cloudinary (document storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Sentry (error monitoring)
SENTRY_DSN=your_sentry_dsn

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# Vector Store
FAISS_INDEX_PATH=./data/vectorstore/nyaya_index
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=8
